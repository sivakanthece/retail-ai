# ── Copy this file to .env and fill in your values ───────────────────────────
# Never commit .env — it is listed in .gitignore

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./retail.db
# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/retaildb

# ── AI Vision providers (at least one required for LLM identification) ────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ── Model settings ────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
# Set to best.pt if you have a custom-trained YOLOv8 model in backend/
YOLO_MODEL=yolov8n.pt
MAX_UPLOAD_SIZE_MB=20
